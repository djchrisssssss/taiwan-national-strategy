{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chapter Statistics",
  "description": "Schema for per-chapter statistics data files",
  "type": "object",
  "required": ["chapter", "title", "last_updated", "statistics"],
  "properties": {
    "chapter": {
      "type": "string",
      "description": "Chapter identifier (e.g., '01', '02', '16')"
    },
    "title": {
      "type": "string",
      "description": "Chapter title in English"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date in ISO 8601 format"
    },
    "statistics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "metric",
          "value",
          "unit",
          "date",
          "source",
          "evidence_tier",
          "claim_type",
          "confidence_level",
          "verification_mode"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ch[0-9]{2}-[0-9]{3}$",
            "description": "Unique identifier (e.g., 'ch01-001')"
          },
          "metric": {
            "type": "string",
            "description": "What is being measured"
          },
          "value": {
            "oneOf": [
              { "type": "number" },
              { "type": "string" }
            ],
            "description": "The measured value (number or descriptive string)"
          },
          "unit": {
            "type": "string",
            "description": "Unit of measurement (e.g., 'percent', 'USD billion', 'days')"
          },
          "date": {
            "type": "string",
            "description": "Date or period of the measurement (e.g., '2025', '2025-Q3')"
          },
          "source": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Source organization or publication name"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "URL to the source"
              },
              "doi": {
                "type": ["string", "null"],
                "description": "DOI if available"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed"
              }
            }
          },
          "context": {
            "type": "string",
            "description": "Additional context for the data point"
          },
          "verified": {
            "type": "boolean",
            "description": "Whether this data point has been source-checked and documented"
          },
          "verification_note": {
            "type": "string",
            "description": "Notes on verification methodology"
          },
          "evidence_tier": {
            "type": "string",
            "enum": [
              "tier_1_primary",
              "tier_2_secondary",
              "tier_3_estimate",
              "tier_4_forward_looking"
            ],
            "description": "Evidence strength tier ranging from primary official records to forward-looking targets and scenarios"
          },
          "claim_type": {
            "type": "string",
            "enum": [
              "measured_statistic",
              "case_count",
              "geographic_measurement",
              "market_estimate",
              "policy_target",
              "scenario_or_timeline"
            ],
            "description": "The claim category represented by the data point"
          },
          "confidence_level": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Confidence in the specific figure or claim framing"
          },
          "verification_mode": {
            "type": "string",
            "enum": [
              "official_publication_check",
              "cross_source_check",
              "single_source_check",
              "registry_case_check",
              "policy_document_check"
            ],
            "description": "How the data point was verified or contextualized"
          }
        }
      }
    }
  }
}
