{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chapter Statistics",
  "description": "Schema for per-chapter statistics data files",
  "type": "object",
  "required": ["chapter", "title", "last_updated", "statistics"],
  "properties": {
    "chapter": {
      "type": "string",
      "description": "Chapter identifier (e.g., '01', '02', 'S1')"
    },
    "title": {
      "type": "string",
      "description": "Chapter title in English"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date in ISO 8601 format"
    },
    "statistics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "metric", "value", "unit", "date", "source"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(ch[0-9]{2}|S[0-9])-[0-9]{3}$",
            "description": "Unique identifier (e.g., 'ch01-001')"
          },
          "metric": {
            "type": "string",
            "description": "What is being measured"
          },
          "value": {
            "oneOf": [
              { "type": "number" },
              { "type": "string" }
            ],
            "description": "The measured value (number or descriptive string)"
          },
          "unit": {
            "type": "string",
            "description": "Unit of measurement (e.g., 'percent', 'USD billion', 'days')"
          },
          "date": {
            "type": "string",
            "description": "Date or period of the measurement (e.g., '2025', '2025-Q3')"
          },
          "source": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Source organization or publication name"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "URL to the source"
              },
              "doi": {
                "type": ["string", "null"],
                "description": "DOI if available"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed"
              }
            }
          },
          "context": {
            "type": "string",
            "description": "Additional context for the data point"
          },
          "verified": {
            "type": "boolean",
            "description": "Whether this data point has been independently verified"
          },
          "verification_note": {
            "type": "string",
            "description": "Notes on verification methodology"
          }
        }
      }
    }
  }
}
